datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Agent {
  id        String   @id @default(cuid())
  matricule String   @unique
  nom       String
  postnom   String?
  prenom    String?
  fonction  String
  service   String
  telephone String?
  email     String?
  photo     String?
  qrCode    String?
  statut    String   @default("ACTIF")
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
