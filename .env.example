# App Rigos environment variables

# PostgreSQL connection string.
# On Vercel, use the pooled connection URL from Vercel Postgres, Neon, Supabase, Railway, etc.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"

# Public application URL.
# Local:
NEXTAUTH_URL="http://localhost:3000"
# Production example:
# NEXTAUTH_URL="https://your-vercel-project.vercel.app"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace_with_a_long_random_secret"

# Credentials used by the built-in credentials provider.
ADMIN_EMAIL="admin@app-rigos.local"
ADMIN_PASSWORD="Admin123!"
OPERATOR_EMAIL="operator@app-rigos.local"
OPERATOR_PASSWORD="Operator123!"
