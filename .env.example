# Exemple de fichier d'environnement pour App Rigos
# Copier ce fichier en `.env` et remplacer les valeurs par vos informations

# Connexion PostgreSQL (remplacez USER, PASSWORD, HOST, PORT et DBNAME)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# URL de l'application (utilisée pour générer les liens/QR)
NEXTAUTH_URL=http://localhost:3000

# Secret pour NextAuth (en production, mettez une valeur longue et aléatoire)
NEXTAUTH_SECRET=changez_ceci_par_une_valeur_secrete_longue

# Identifiants par défaut (optionnel — peuvent rester ceux du code source)
ADMIN_EMAIL=admin@app-rigos.local
ADMIN_PASSWORD=Admin123!
OPERATOR_EMAIL=operator@app-rigos.local
OPERATOR_PASSWORD=Operator123!

# Notes:
# 1) Après avoir configuré `.env`, exécutez :
#    npm install
#    npx prisma generate
#    npx prisma db push   # ou `npx prisma migrate dev --name init`
#    npm run dev
# 2) Assurez-vous d'avoir une instance PostgreSQL accessible et
#    que la valeur de `DATABASE_URL` est correcte.# Remplacez par l'URL de connexion PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/app_rigos"

# URL publique de l'application
NEXTAUTH_URL="http://localhost:3000"

# Utilisateurs d'authentification pour NextAuth
ADMIN_EMAIL="admin@app-rigos.local"
ADMIN_PASSWORD="Admin123!"
OPERATOR_EMAIL="operator@app-rigos.local"
OPERATOR_PASSWORD="Operator123!"
